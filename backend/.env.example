# PostgreSQL (Neon): use a postgresql:// URL only — not the psql CLI command.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"
PORT=4000

# Required for admin JWT signing (min 16 characters in production).
JWT_SECRET="replace-with-a-long-random-secret-at-least-16-chars"
JWT_EXPIRES_IN="7d"

# Used by `npm run db:seed` to create/update the default admin account.
ADMIN_EMAIL="admin@hemolink.et"
ADMIN_PASSWORD="changeme"

# Optional: required in .env when registering additional admins after the first (via POST /api/auth/register).
# First admin can register when the Admin table is empty without this key.
ADMIN_REGISTER_SECRET=""
