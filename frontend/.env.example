# Production / Render static site (set in Render → Environment, BEFORE build):
# Full URL of your BACKEND web service only — no path, no trailing slash.
# Example: https://hemolink-api-xxxx.onrender.com
# VITE_API_URL=https://your-backend.onrender.com
#
# Local dev: leave unset — Vite proxies /api to http://127.0.0.1:4000 (override with VITE_DEV_PROXY if needed).
